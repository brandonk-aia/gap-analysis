# ============================================================
#  AIA Gap Analysis Platform — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit real keys to source control.
# ============================================================

# ── Supabase Project ─────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here-keep-secret

# ── Direct PostgreSQL Connection ─────────────────────────────
# Use this to run database.sql migrations (psql, DBeaver, etc.)
# Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# ── App Settings ─────────────────────────────────────────────
APP_ENV=development
SESSION_DURATION_DAYS=7
